# Copy to `.env` and fill in values.

# RocketRide DAP (optional if you use USE_DIRECT_GEMINI / GEMINI fallback)
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_API_KEY=

# Used by `.pipe` files as ${ROCKETRIDE_GEMINI_API_KEY}; also accepted as a Gemini key by app.py
ROCKETRIDE_GEMINI_API_KEY=

# Google Gemini — required when RocketRide is not running (connection refused), or set USE_DIRECT_GEMINI=1
GEMINI_API_KEY=

# Optional
# USE_DIRECT_GEMINI=1
# GEMINI_MODEL=gemini-2.5-flash
# INSPECTION_REFERENCE_PDF_DIR=
# Legacy alias: USER_RAG_PDF_DIR

# Pipe routing overrides (uncommon)
# RAG_PIPE_USE_CHAT=1
# RAG_PIPE_PROVIDER=RAG_Node
# VISION_PIPE_PROVIDER=Vision_Node
